{
  "name": "tecopos-nest-technical-test",
  "version": "0.0.1",
  "description": "TECOPOS Microservices - Gateway, SSO & Banking",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "build:gateway": "nest build gateway",
    "build:sso": "nest build sso",
    "build:banking": "nest build banking",
    "format": "prettier --write \"apps/**/*.ts\"",
    "start:gateway": "nest start gateway",
    "start:sso": "nest start sso",
    "start:banking": "nest start banking",
    "start:gateway:dev": "nest start gateway --watch",
    "start:sso:dev": "nest start sso --watch",
    "start:banking:dev": "nest start banking --watch",
    "start:dev": "concurrently \"npm run start:gateway:dev\" \"npm run start:sso:dev\" \"npm run start:banking:dev\"",
    "lint": "eslint \"{apps,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "neon:init": "npx --yes neonctl@latest init",
    "db:migrate": "npx sequelize-cli db:migrate --options-path apps/sso/.sequelizerc",
    "db:migrate:undo": "npx sequelize-cli db:migrate:undo --options-path apps/sso/.sequelizerc"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/sequelize": "^10.0.0",
    "@nestjs/swagger": "^7.0.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^17.3.1",
    "pg": "^8.11.0",
    "pg-connection-string": "^2.7.0",
    "pg-hstore": "^2.3.4",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "sequelize": "^6.35.0",
    "sequelize-cli": "^6.6.5",
    "sequelize-typescript": "^2.1.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/"
    ]
  }
}
