# SSO (Neon)
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Banking (MockAPI)
BANKING_API_BASE_URL=https://69caaf2dba5984c44bf3a0d1.mockapi.io/api

# Kafka externo (Aiven / Confluent)
KAFKA_BROKERS=your-kafka-host:your-port
KAFKA_SSL=true
KAFKA_SSL_REJECT_UNAUTHORIZED=true
# Optional: base64-encoded PEM CA certificate (if provider requires custom CA)
# KAFKA_SSL_CA_BASE64=LS0tLS1CRUdJTiBDRVJUSUZJQ0FURS0tLS0t...
KAFKA_SASL_MECHANISM=plain
KAFKA_SASL_USERNAME=your-username
KAFKA_SASL_PASSWORD=your-password

# Gateway HTTP port
PORT=3000
